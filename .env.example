# Example environment variables for this Vite app
#
# Usage:
# 1) Copy this file to ".env.local"
# 2) Adjust values as needed for your local setup
#
# Notes:
# - Vite only exposes variables prefixed with "VITE_" to the client.
# - If a variable is left empty, the app may use its own internal fallback.

# Default search value shown in the input field when the app loads.
# If not set, the app will use these fallbacks:
#   - Dev mode: "TEDx"
#   - Production: "" (empty)
# Example: VITE_DEFAULT_SEARCH=TEDx
VITE_DEFAULT_SEARCH=

# Full git commit hash embedded in the build info footer.
# Optional. Auto-detected from git at build time (vite.config.ts).
# Override only in CI/Docker environments where git history is unavailable.
# Format: 40-char hex SHA, e.g. "a1b2c3d4e5f6..."
# Example: VITE_GIT_COMMIT_HASH=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2
VITE_GIT_COMMIT_HASH=

# Git branch name embedded in the build info footer.
# Optional. Auto-detected from git at build time (vite.config.ts).
# Override only in CI/Docker environments where git history is unavailable.
# Format: branch name string, e.g. "main"
# Example: VITE_GIT_BRANCH=main
VITE_GIT_BRANCH=

# Enable Electron desktop app mode. Set automatically by electron:* npm scripts.
# Do NOT set this in .env.local for normal web/Docker development.
# Required: "true" to activate vite-plugin-electron (compiles electron/main.ts + preload.ts).
# Default: unset (web-only build)
# Example: ELECTRON=true
ELECTRON=
