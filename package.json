{
  "name": "tubetrend",
  "version": "1.0.0",
  "description": "YouTube trend analysis tool - analyze video performance, track favorites, and discover trending content",
  "author": "fo0 <fo0@fo0.me>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fo0/tubetrend.git"
  },
  "bugs": {
    "url": "https://github.com/fo0/tubetrend/issues"
  },
  "homepage": "https://github.com/fo0/tubetrend#readme",
  "keywords": [
    "youtube",
    "trends",
    "analytics",
    "react",
    "vite",
    "typescript"
  ],
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite build && vite preview",
    "electron:dev": "ELECTRON=true vite",
    "electron:preview": "ELECTRON=true vite build && electron .",
    "electron:dist": "ELECTRON=true vite build && npm run electron:icon && electron-builder --config electron-builder.json",
    "electron:icon": "node scripts/generate-icon.mjs",
    "build:chromebook": "ELECTRON=true vite build && npm run electron:icon && electron-builder --config electron-builder.chromebook.json --linux",
    "build:win": "ELECTRON=true vite build && electron-builder --config electron-builder.json --win portable",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:build": "npm run build && npx cap sync android && cd android && ./gradlew assembleRelease",
    "cap:build:debug": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "build:extension": "vite build && node scripts/build-extension.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@fontsource/inter": "^5.2.8",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8"
  },
  "overrides": {
    "electron-builder": {
      "app-builder-lib": {
        "minimatch": {
          "brace-expansion": "^5.0.6"
        }
      }
    }
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^41.6.1",
    "electron-builder": "^26.15.3",
    "prettier": "3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^0.29.1"
  }
}
