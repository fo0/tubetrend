{
  "manifest_version": 3,
  "name": "TubeTrend",
  "description": "YouTube trend analysis tool - analyze video performance, track favorites, and discover trending content",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Open TubeTrend"
  },
  "background": {
    "service_worker": "background.js"
  }
}
