flowchart TD
    subgraph "Entry Points"
        MAIN["main.tsx"]:::frontend
        HTML["index.html"]:::frontend
    end

    subgraph "App Shell"
        APP("App.tsx"):::frontend
        DASHBOARD["DashboardPage"]:::frontend
        ANALYSER["AnalyserPage"]:::frontend
    end

    subgraph "Providers"
        THEME("ThemeProvider"):::frontend
        I18N("i18n Config"):::frontend
        ERRBND("ErrorBoundary"):::frontend
    end

    subgraph "Features"
        subgraph "Dashboard Feature"
            USEDASH("useDashboard hooks"):::feature
            DASHSVC("dashboardServices"):::service
            HIDDEN("hiddenHighlightsService"):::service
        end

        subgraph "Favorites Feature"
            FAVSVC("favoritesService"):::service
            FAVTYPES["FavoriteConfig types"]:::feature
        end

        subgraph "Search Feature"
            USESEARCH("useSearch"):::feature
        end

        subgraph "Videos Feature"
            TREND("trendAnalysisService"):::service
        end

        subgraph "YouTube Feature"
            APICLIENT("youtubeApiClient"):::service
            CHANSVC("channelService"):::service
            SEARCHSVC("searchService"):::service
            QUOTASVC("quotaService"):::service
        end
    end

    subgraph "Shared"
        EVENTBUS("eventBus"):::shared
        STORAGE("StorageAdapter"):::shared
        UICOMPS["UI Components"]:::shared
        HOOKS["Custom Hooks"]:::shared
        CONSTANTS["Constants"]:::shared
    end

    subgraph "External"
        YTAPI{{"YouTube Data API v3"}}:::external
        LOCALSTORAGE[("localStorage")]:::storage
    end

    subgraph "Distribution"
        ELECTRON["Electron Desktop"]:::infra
        CAPACITOR["Capacitor Android"]:::infra
        CHROMEEXT["Chrome Extension"]:::infra
        DOCKER["Docker / Nginx"]:::infra
    end

    HTML --> MAIN
    MAIN --> THEME
    MAIN --> I18N
    MAIN --> ERRBND
    ERRBND --> APP
    APP --> DASHBOARD
    APP --> ANALYSER

    DASHBOARD --> USEDASH
    USEDASH --> DASHSVC
    USEDASH --> FAVSVC
    USEDASH --> HIDDEN
    ANALYSER --> USESEARCH
    USESEARCH --> SEARCHSVC
    USESEARCH --> TREND

    SEARCHSVC --> APICLIENT
    CHANSVC --> APICLIENT
    FAVSVC -->|"fetch videos"| APICLIENT
    APICLIENT -->|"REST calls"| YTAPI
    APICLIENT -->|"track usage"| QUOTASVC

    FAVSVC --> STORAGE
    QUOTASVC --> STORAGE
    HIDDEN --> STORAGE
    DASHSVC --> STORAGE
    THEME --> STORAGE
    STORAGE --> LOCALSTORAGE

    FAVSVC -->|"emit events"| EVENTBUS
    QUOTASVC -->|"emit events"| EVENTBUS
    HIDDEN -->|"emit events"| EVENTBUS
    USEDASH -->|"listen events"| EVENTBUS

    APP --> UICOMPS

    ELECTRON -->|"wraps dist/"| APP
    CAPACITOR -->|"wraps dist/"| APP
    CHROMEEXT -->|"wraps dist/"| APP
    DOCKER -->|"serves dist/"| APP

